<Window x:Class="BadmintonManagement.GUI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - The Champions" Height="500" Width="400"  
        WindowStartupLocation="CenterScreen" AllowsTransparency="True" WindowStyle="None" Background="Transparent">

    <Border CornerRadius="20" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel Margin="30">
            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                    Foreground="#b2bec3" Margin="0,-20,-10,10" Cursor="Hand" Click="btnExit_Click"/>

            <TextBlock Text="🏸" FontSize="40" HorizontalAlignment="Center" Margin="0,10"/>
            <TextBlock Text="THE CHAMPIONS" FontSize="20" FontWeight="Black" Foreground="#0984e3" HorizontalAlignment="Center"/>
            <TextBlock Text="Hệ thống quản lý sân cầu lông" FontSize="10" Foreground="#b2bec3" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border x:Name="brdAlert" Background="#fab1a0" CornerRadius="8" Padding="10,8" Margin="0,0,0,15" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⚠️" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtAlertMessage" Grid.Column="1" Text="Thông báo lỗi" FontSize="12" 
                               Foreground="#d63031" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#dfe6e9"/>

            <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="10,0" BorderBrush="#dfe6e9"/>

            <TextBlock HorizontalAlignment="Right" Margin="0,0,0,20">
                <Hyperlink Foreground="#636e72" FontSize="11" TextDecorations="None" 
                           x:Name="linkForgotPass" Click="linkForgotPass_Click">
                    Quên mật khẩu?
                </Hyperlink>
            </TextBlock>

            <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" Background="#0984e3" Foreground="White" FontWeight="Bold" Height="42" Cursor="Hand" Click="btnLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="21"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Đăng ký tài khoản mới" Click="btnGoToRegister_Click" 
                    Background="Transparent" BorderThickness="0" Foreground="#0984e3" Margin="0,15,0,0" Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>