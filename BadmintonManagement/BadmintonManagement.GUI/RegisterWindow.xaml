<Window x:Class="BadmintonManagement.GUI.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký thành viên - The Champions" Height="680" Width="400" 
        WindowStartupLocation="CenterScreen" AllowsTransparency="True" WindowStyle="None" Background="Transparent">

    <Border CornerRadius="20" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>
        <Grid>
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" 
                    Background="Transparent" BorderThickness="0" Foreground="#b2bec3" 
                    Click="btnBackToLogin_Click" Panel.ZIndex="2" Cursor="Hand"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
                <StackPanel Margin="30,15,30,30">
                    <TextBlock Text="🏸" FontSize="35" HorizontalAlignment="Center" Margin="0,5"/>
                    <TextBlock Text="ĐĂNG KÝ THÀNH VIÊN" FontSize="18" FontWeight="Black" Foreground="#0984e3" HorizontalAlignment="Center"/>
                    <TextBlock Text="Gia nhập cộng đồng The Champions" FontSize="10" Foreground="#b2bec3" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <Border x:Name="brdAlert" Background="#fab1a0" CornerRadius="8" Padding="10,8" Margin="0,0,0,15" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚠️" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="txtAlertMessage" Grid.Column="1" Text="Thông báo lỗi" FontSize="11" 
                                       Foreground="#d63031" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Họ và Tên" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <TextBox x:Name="txtFullName" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <TextBox x:Name="txtPhone" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <TextBlock Text="Gmail" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <TextBox x:Name="txtEmail" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <TextBox x:Name="txtUsername" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <PasswordBox x:Name="txtPassword" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <TextBlock Text="Xác nhận mật khẩu" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#2d3436"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="32" Margin="0,0,0,20" VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#dfe6e9"/>

                    <Button x:Name="btnRegister" Content="ĐĂNG KÝ NGAY" Background="#2ecc71" Foreground="White" FontWeight="Bold" Height="42" Cursor="Hand" Click="btnRegister_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="21"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button Content="Đã có tài khoản? Đăng nhập" Background="Transparent" BorderThickness="0" Foreground="#636e72" Margin="0,12,0,0" Cursor="Hand" Click="btnBackToLogin_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>