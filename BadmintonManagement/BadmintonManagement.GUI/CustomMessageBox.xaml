<Window x:Class="BadmintonManagement.GUI.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông báo" Height="180" Width="350" 
        WindowStartupLocation="CenterScreen" AllowsTransparency="True" 
        WindowStyle="None" Background="Transparent" Topmost="True">

    <Border CornerRadius="15" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <StackPanel Margin="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock x:Name="txtIcon" Text="✨" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtMessage" Text="Nội dung thông báo" FontSize="14" 
                               FontWeight="SemiBold" Foreground="#2d3436" VerticalAlignment="Center" 
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>
                </StackPanel>

                <Button x:Name="btnOK" Content="Đã hiểu" Width="100" Height="35" 
                        Background="#0984e3" Foreground="White" FontWeight="Bold" 
                        Cursor="Hand" Click="btnOK_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>