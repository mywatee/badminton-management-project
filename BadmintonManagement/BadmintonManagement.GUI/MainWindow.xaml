<Window x:Class="BadmintonManagement.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="The Champions - Badminton Management" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="MainBgGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7FAFC" Offset="0"/>
            <GradientStop Color="#EDF2F7" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GlassBrush" Color="White" Opacity="0.8"/>

        <Style TargetType="Button" x:Key="IconMenuButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#636e72"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="TrelloCardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource MainBgGradient}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A202C" Margin="10" CornerRadius="20">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Margin="15,25">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,40">
                        <Border Width="40" Height="40" Background="#4ADE80" CornerRadius="10">
                            <TextBlock Text="⚡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock Text="QLSANCL" FontWeight="Bold" Foreground="White" FontSize="16"/>
                            <TextBlock Text="The Champions" Foreground="#A0AEC0" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{StaticResource IconMenuButtonStyle}" Background="#4ADE80" Foreground="Black">
                        <StackPanel Orientation="Horizontal" Width="160">
                            <TextBlock Text="📊" Margin="0,0,15,0"/>
                            <TextBlock Text="Bảng điều khiển" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White">
                        <StackPanel Orientation="Horizontal" Width="160">
                            <TextBlock Text="📅" Margin="0,0,15,0"/>
                            <TextBlock Text="Đặt sân" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White">
                        <StackPanel Orientation="Horizontal" Width="160">
                            <TextBlock Text="🎾" Margin="0,0,15,0"/>
                            <TextBlock Text="Dịch vụ" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White">
                        <StackPanel Orientation="Horizontal" Width="160">
                            <TextBlock Text="👥" Margin="0,0,15,0"/>
                            <TextBlock Text="Khách hàng" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="15,20">
                    <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White" Content="⚙️ Cài đặt"/>
                    <Border Background="#2D3748" CornerRadius="15" Padding="10" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="35" Height="35" Fill="#4ADE80"/>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock x:Name="txtUserDisplayName" Text="Huy Hoàng" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                <TextBlock Text="Quản trị viên" Foreground="#A0AEC0" FontSize="10"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20,30,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Bảng điều khiển" FontSize="28" FontWeight="Bold" Foreground="#2D3748"/>
                    <TextBlock Text="Chào mừng trở lại! Đây là tình hình hôm nay." Foreground="#718096" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtBigTime" Text="12:00" FontSize="26" FontWeight="Light" Foreground="#2d3436"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="txtDate" Text="17/03/2026" FontSize="11" FontWeight="SemiBold" Foreground="#636e72"/>
                        <TextBlock Text="LÀM VIỆC" FontSize="9" FontWeight="Bold" Foreground="#0984e3"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,25">
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="45" Height="45" Fill="#E3F2FD" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu ngày" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="₫2,450,000" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TrelloCardStyle}" Margin="5" Background="#E8F5E9">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="#4ADE80" CornerRadius="12" Margin="0,0,15,0">
                            <TextBlock Text="🏟️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Sân đang trống" FontSize="12" Foreground="#2E7D32"/>
                            <TextBlock x:Name="txtStatusCount" Text="0/8" FontSize="18" FontWeight="Black" Foreground="#1B5E20"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="45" Height="45" Fill="#F3E5F5" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Khách mới" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="12 khách" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="45" Height="45" Fill="#FFF3E0" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tỷ lệ lấp đầy" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="85%" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <UniformGrid Grid.Row="2" Columns="4">
                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SÂN TRỐNG" FontWeight="Bold" Foreground="#172B4D" Margin="5,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icSanSan">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#4ADE80" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172B4D"/>
                                                <TextBlock Text="Sẵn sàng" FontSize="11" Foreground="#4ADE80"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ĐANG THI ĐẤU" FontWeight="Bold" Foreground="#172B4D" Margin="5,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icDangSuDung">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#0984e3" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172B4D"/>
                                                    <TextBlock Text="{Binding ThoiGianConLai}" HorizontalAlignment="Right" Foreground="#0984e3" FontWeight="Bold"/>
                                                </Grid>
                                                <TextBlock Text="{Binding TenKhach}" FontSize="12" Foreground="#636e72" Margin="0,5"/>
                                                <ProgressBar Value="{Binding ProgressValue}" Height="6" Foreground="#0984e3" Background="#dfe6e9" BorderThickness="0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="LỊCH TRONG NGÀY" FontWeight="Bold" Foreground="#172B4D" Margin="5,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icKhachDoi">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#f1c40f" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" FontSize="12" Foreground="#172B4D"/>
                                                <TextBlock Text="{Binding ThongTinCho}" FontSize="11" Foreground="#f39c12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="BẢO TRÌ" FontWeight="Bold" Foreground="#172B4D" Margin="5,0,0,15"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icBaoTri">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#e74c3c" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172B4D"/>
                                                <TextBlock Text="Đang sửa chữa" FontSize="11" Foreground="#e74c3c"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>