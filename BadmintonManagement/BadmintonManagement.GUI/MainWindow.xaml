<Window x:Class="BadmintonManagement.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="The Champions - Badminton Management" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="Button" x:Key="IconMenuButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#636e72"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="5,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#dfe6e9"/>
                                <Setter Property="Foreground" Value="#0984e3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Border" x:Key="TrelloCardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/bg.jpg" Stretch="UniformToFill" Opacity="1" />
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#CCF1F2F6" Margin="10" CornerRadius="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.05"/>
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" VerticalAlignment="Top" Margin="0,20">
                    <TextBlock Text="🏸" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="🏠" ToolTip="Trang chủ"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="🏟️" x:Name="btnCourt" Click="btnCourt_Click" ToolTip="Sơ đồ sân"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="📅" ToolTip="Lịch đặt" Tag="5"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="👥" ToolTip="Khách hàng"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="🛒" ToolTip="Dịch vụ"/>
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="📊" ToolTip="Báo cáo"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,20">
                    <Button Style="{StaticResource IconMenuButtonStyle}" Content="⚙️" ToolTip="Cài đặt"/>
                    <Button Margin="0,10,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate>
                                <Grid HorizontalAlignment="Center">
                                    <Ellipse Width="40" Height="40" Fill="#3498DB"/>
                                    <TextBlock Text="H" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Ellipse Width="12" Height="12" Fill="#2ECC71" Stroke="White" StrokeThickness="2" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                                </Grid>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="10,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,30,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="THE" FontSize="11" FontWeight="Light" Foreground="#2d3436" VerticalAlignment="Bottom" Margin="0,0,4,3"/>
                        <TextBlock Text="CHAMPIONS" FontSize="18" FontWeight="Black" Foreground="#0984e3"/>
                    </StackPanel>
                    <TextBlock Text="Hệ thống quản lý sân chuyên nghiệp" FontSize="9" FontWeight="SemiBold" Foreground="#b2bec3" Margin="2,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#40FFFFFF" CornerRadius="20" Height="40" Width="200">
                        <StackPanel Orientation="Horizontal" Margin="15,0">
                            <TextBlock Text="🔍" VerticalAlignment="Center" Foreground="#4b4b4b" Opacity="0.6"/>
                            <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Width="140" Margin="10,0" Foreground="#2d3436" Text="Tìm kiếm..."/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnNewBooking" Click="btnNewBooking_Click" Background="#00D2D3" Foreground="White" Width="130" Height="38" BorderThickness="0" Margin="15,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="19"/>
                            </Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="20" FontWeight="Bold" Margin="0,-2,8,0"/>
                            <TextBlock Text="Đặt sân mới" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Background="#2000D2D3" CornerRadius="15" Padding="12,5" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#00D2D3" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center">
    <Run Text="Trống:" FontSize="11" Foreground="#636e72"/>
    <Run x:Name="txtStatusCount" Text=" 0/8" FontWeight="Bold" Foreground="#2d3436" FontSize="12"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtBigTime" Text="12:00" FontSize="26" FontWeight="Light" Foreground="#2d3436"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtDate" Text="16/03/2026" FontSize="11" FontWeight="SemiBold" Foreground="#636e72"/>
                            <TextBlock Text="LÀM VIỆC" FontSize="9" FontWeight="Bold" Foreground="#0984e3" Opacity="0.8"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Huy Hoàng" FontWeight="Bold" Foreground="#2F3542" HorizontalAlignment="Right"/>
                        <TextBlock Text="Admin" FontSize="11" Foreground="#00D2D3" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Ellipse Width="40" Height="40" Fill="#3498DB"/>
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4" Height="100" Margin="10,10,10,0">
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Grid Margin="0,0,15,0">
                            <Ellipse Width="45" Height="45" Fill="#E3F2FD"/>
                            <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu ngày" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="₫2,450,000" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Grid Margin="0,0,15,0">
                            <Ellipse Width="45" Height="45" Fill="#F3E5F5"/>
                            <TextBlock Text="📅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Lượt đặt" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="42 lượt" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Grid Margin="0,0,15,0">
                            <Ellipse Width="45" Height="45" Fill="#E8F5E9"/>
                            <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Khách mới" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="12 khách" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource TrelloCardStyle}" Margin="5">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                        <Grid Margin="0,0,15,0">
                            <Ellipse Width="45" Height="45" Fill="#FFF3E0"/>
                            <TextBlock Text="📈" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Lấp đầy" FontSize="12" Foreground="#636e72"/>
                            <TextBlock Text="85%" FontSize="18" FontWeight="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <UniformGrid Grid.Row="2" Columns="4" Margin="0,20,0,0">

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="SÂN TRỐNG" FontWeight="Bold" Foreground="#172b4d" Margin="5,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icSanSan">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#2ecc71" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172b4d"/>
                                                <TextBlock Text="Sẵn sàng" FontSize="11" Foreground="#27ae60"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ĐANG THI ĐẤU" FontWeight="Bold" Foreground="#172b4d" Margin="5,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icDangSuDung">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#0984e3" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172b4d"/>
                                                    <TextBlock Text="{Binding ThoiGianConLai}" HorizontalAlignment="Right" Foreground="#0984e3" FontWeight="Bold"/>
                                                </Grid>
                                                <TextBlock Text="{Binding TenKhach}" FontSize="12" Foreground="#636e72" Margin="0,5"/>
                                                <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}" Height="6" Margin="0,5,0,0" Foreground="#0984e3" Background="#dfe6e9" BorderThickness="0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="LỊCH ĐẶT TRONG NGÀY" FontWeight="Bold" Foreground="#172b4d" Margin="5,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icKhachDoi">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#f1c40f" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" FontSize="12" Foreground="#172b4d"/>
                                                <TextBlock Text="{Binding ThongTinCho}" FontSize="11" Foreground="#f39c12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Background="#ebecf0" Margin="8" CornerRadius="10" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="BẢO TRÌ" FontWeight="Bold" Foreground="#172b4d" Margin="5,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icBaoTri">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TrelloCardStyle}" BorderBrush="#e74c3c" BorderThickness="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#172b4d"/>
                                                <TextBlock Text="Đang sửa chữa / Tạm dừng" FontSize="11" Foreground="#e74c3c"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

            </UniformGrid>
        </Grid>
    </Grid>
</Window>