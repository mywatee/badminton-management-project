                        <TextBlock Text="⚡" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="QLSANCL" FontWeight="Bold" Foreground="White" FontSize="16"/>
                        <TextBlock Text="Quản lý sân cầu" Foreground="#A0AEC0" FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <Button Style="{StaticResource IconMenuButtonStyle}" Background="#4ADE80" Foreground="Black" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Width="160">
                        <TextBlock Text="📊" Margin="0,0,15,0"/>
                        <TextBlock Text="Bảng điều khiển" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Width="160">
                        <TextBlock Text="📅" Margin="0,0,15,0"/>
                        <TextBlock Text="Đặt sân" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Width="160">
                        <TextBlock Text="🎾" Margin="0,0,15,0"/>
                        <TextBlock Text="Dịch vụ" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource IconMenuButtonStyle}" Foreground="White" Margin="0,5">
                    <StackPanel Orientation="Horizontal" Width="160">
                        <TextBlock Text="👥" Margin="0,0,15,0"/>
                        <TextBlock Text="Khách hàng" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="20,30,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10,0,0,25">
                <TextBlock Text="Bảng điều khiển" FontSize="28" FontWeight="Bold" Foreground="#2D3748"/>
                <TextBlock Text="Chào mừng trở lại! Đây là tình hình hôm nay." Foreground="#718096" FontSize="14"/>
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,25">
                <Border Background="{StaticResource GlassBrush}" CornerRadius="20" Margin="8" Padding="20">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Width="45" Height="45" Background="#4ADE80" CornerRadius="12">
                            <TextBlock Text="₫" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Doanh thu ngày" Foreground="#718096" FontSize="12"/>
                            <TextBlock Text="₫2.450.000" FontSize="20" FontWeight="Bold" Margin="0,5"/>
                            <TextBlock Text="▲ 12.5%" Foreground="#4ADE80" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource GlassBrush}" CornerRadius="25" Margin="8" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Trạng thái sân" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <UniformGrid Columns="4" x:Name="icSanStatus">
                            <Border Background="White" CornerRadius="15" Margin="8" Padding="15" BorderBrush="#EDF2F7" BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="40" Height="40" Background="#1A202C" CornerRadius="10">
                                        <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Sân số 1" FontWeight="Bold" Margin="0,10,0,2"/>
                                    <TextBlock Text="Trong nhà" FontSize="10" Foreground="#A0AEC0"/>
                                    <Border Background="#E1F9EB" CornerRadius="8" Padding="10,4" Margin="0,10,0,0">
                                        <TextBlock Text="Sẵn sàng" Foreground="#4ADE80" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource GlassBrush}" CornerRadius="25" Margin="8" Padding="25">
                    <StackPanel>
                        <TextBlock Text="Lịch đặt gần đây" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="icRecentBookings">
                            <Border BorderBrush="#EDF2F7" BorderThickness="0,0,0,1" Padding="0,12">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Background="#E1F9EB" CornerRadius="6" Padding="6,2">
                                        <TextBlock Text="Đã nhận" Foreground="#4ADE80" FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Nguyễn Văn A" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="Sân 1 | 14:00 - 15:00" FontSize="11" Foreground="#A0AEC0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>