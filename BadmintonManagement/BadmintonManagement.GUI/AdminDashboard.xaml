<Window x:Class="BadmintonManagement.GUI.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="The Champions - Badminton Management" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#f1f5f9"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#0f172a" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="⚡ QLSANCL" FontSize="24" FontWeight="Bold" Foreground="#10b981"/>
                    <TextBlock Text="The Champions" FontSize="12" Foreground="#94a3b8" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Menu Items -->
                <StackPanel Grid.Row="1" Margin="20,20,20,0">
                    <Button Content="📊 Bảng điều khiển" Style="{StaticResource MenuButtonActive}" Click="btnCourt_Click"/>
                    <Button Content="📅 Đặt sân" Style="{StaticResource MenuButton}" Margin="0,10,0,0"/>
                    <Button Content="💁 Dịch vụ" Style="{StaticResource MenuButton}" Margin="0,10,0,0"/>
                    <Button Content="👥 Khách hàng" Style="{StaticResource MenuButton}" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- User Info Footer trong Sidebar -->
                <Border Grid.Row="2" Background="#1e293b" CornerRadius="10" Margin="15">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Ellipse Width="35" Height="35" Fill="#10b981" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <!-- Tên người dùng -->
                            <TextBlock x:Name="txtUserDisplayName" Text="Đang tải..." Foreground="White" FontWeight="Bold" FontSize="14"/>

                            <!-- Vai trò người dùng (Cần thêm cái này) -->
                            <TextBlock x:Name="txtUserRole" Text="..." Foreground="#94a3b8" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT (Grid Column 1) -->
        <Grid Grid.Column="1" Background="#f1f5f9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- PHẦN 1: HEADER & THỐNG KÊ -->
            <StackPanel Grid.Row="0" Margin="30,30,30,20">
                <!-- Header Tiêu đề & Đồng hồ -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Bảng điều khiển" FontSize="32" FontWeight="Bold" Foreground="#334155"/>
                        <TextBlock Text="Chào mừng trở lại! Đây là tình hình hôm nay." Foreground="#64748b" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="txtBigTime" Text="22:11" FontSize="36" FontWeight="Light" Foreground="#0f172a" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="txtDate" Text="17-03-2026" Foreground="#10b981" FontSize="12" HorizontalAlignment="Right" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>

                <!-- 4 Thẻ Thống Kê -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Doanh thu -->
                    <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,0" BorderBrush="#e2e8f0" BorderThickness="1">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="50"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Doanh thu ngày" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="đ2,450,000" FontSize="20" FontWeight="Bold" Foreground="#0f172a" Margin="0,5,0,0" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#dbeafe" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 2: Sân trống -->
                    <Border Grid.Column="1" Background="#dcfce7" CornerRadius="15" Padding="20" Margin="5,0" BorderBrush="#bbf7d0" BorderThickness="1">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Sân đang trống" Foreground="#15803d" FontSize="13" FontWeight="Bold"/>
                                <TextBlock x:Name="txtStatusCount" Text="7/8" FontSize="24" FontWeight="Bold" Foreground="#166534" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#bbf7d0" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="🏸" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 3: Khách mới -->
                    <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="20" Margin="5,0" BorderBrush="#e2e8f0" BorderThickness="1">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Khách mới" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="12 khách" FontSize="24" FontWeight="Bold" Foreground="#0f172a" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#f3e8ff" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Card 4: Tỷ lệ lấp đầy -->
                    <Border Grid.Column="3" Background="White" CornerRadius="15" Padding="20" Margin="10,0,0,0" BorderBrush="#e2e8f0" BorderThickness="1">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Tỷ lệ lấp đầy" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="85%" FontSize="24" FontWeight="Bold" Foreground="#0f172a" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#ffedd5" CornerRadius="10" Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- PHẦN 2: 4 CỘT DỮ LIỆU KANBAN -->
            <Grid Grid.Row="1" Margin="30,0,30,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cột 1: Sân Trống -->
                <Border Grid.Column="0" Background="#f8fafc" CornerRadius="15" Padding="15" Margin="0,0,10,0" BorderBrush="#e2e8f0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="SÂN TRỐNG" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icSanSan">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#10b981" BorderThickness="0,0,0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#0f172a" FontSize="16"/>
                                                <TextBlock Text="Sẵn sàng" Foreground="#10b981" FontSize="12" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Cột 2: Đang Thi Đấu -->
                <Border Grid.Column="1" Background="#f8fafc" CornerRadius="15" Padding="15" Margin="5,0" BorderBrush="#e2e8f0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ĐANG THI ĐẤU" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icDangSuDung">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#3b82f6" BorderThickness="0,0,0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#0f172a" FontSize="16"/>
                                                <TextBlock Text="{Binding TenKhach}" Foreground="#64748b" FontSize="13" Margin="0,5,0,0"/>
                                                <ProgressBar Value="{Binding ProgressValue}" Height="4" Margin="0,10,0,0" Maximum="100" Minimum="0" Foreground="#3b82f6" Background="#e2e8f0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Cột 3: Lịch Trong Ngày -->
                <Border Grid.Column="2" Background="#f8fafc" CornerRadius="15" Padding="15" Margin="5,0" BorderBrush="#e2e8f0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="LỊCH TRONG NGÀY" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icKhachDoi">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#f59e0b" BorderThickness="0,0,0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#0f172a" FontSize="16"/>
                                                <TextBlock Text="{Binding ThongTinCho}" Foreground="#64748b" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Cột 4: Bảo Trì -->
                <Border Grid.Column="3" Background="#f8fafc" CornerRadius="15" Padding="15" Margin="10,0,0,0" BorderBrush="#e2e8f0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="BẢO TRÌ" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icBaoTri">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,10" BorderBrush="#ef4444" BorderThickness="0,0,0,3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding TenSan}" FontWeight="Bold" Foreground="#0f172a" FontSize="16"/>
                                                <TextBlock Text="Đang sửa chữa" Foreground="#ef4444" FontSize="12" Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
            <!-- Kết thúc Grid Row 1 (Kanban) -->

        </Grid>
        <!-- Kết thúc Grid Column 1 (Main Content) -->

    </Grid>
    <!-- Kết thúc Grid chính của Window -->
</Window>