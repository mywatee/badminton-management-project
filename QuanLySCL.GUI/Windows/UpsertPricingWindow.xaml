<Window x:Class="QuanLySCL.GUI.Windows.UpsertPricingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Cấu hình Giá" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">

    <Border BorderBrush="{StaticResource NavyBlueLight}" BorderThickness="0" Background="White" CornerRadius="12">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <Grid>
                    <materialDesign:PackIcon Kind="CashEdit" Width="24" Height="24" Foreground="{StaticResource LimeGreen}" VerticalAlignment="Center"/>
                    <TextBlock Text="Cấu hình Giá" FontSize="22" FontWeight="Bold" Foreground="{StaticResource NavyBlueBrush}" Margin="32,0,0,0"/>
                </Grid>
                <Separator Background="#F1F5F9" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ComboBox x:Name="CbCourtType" 
                              materialDesign:HintAssist.Hint="Loại sân"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Margin="0,0,0,16" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                    <ComboBox x:Name="CbTimeSlot" 
                              materialDesign:HintAssist.Hint="Ca giờ"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Margin="0,0,0,16" DisplayMemberPath="DisplayLabel" SelectedValuePath="Id"/>

                    <ComboBox x:Name="CbBookingType" 
                              materialDesign:HintAssist.Hint="Hình thức thuê"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Margin="0,0,0,16">
                        <ComboBoxItem Content="Lẻ" Tag="Lẻ"/>
                        <ComboBoxItem Content="Cố định" Tag="Cố định"/>
                    </ComboBox>

                    <TextBox x:Name="TxtPrice" 
                             materialDesign:HintAssist.Hint="Đơn giá (VNĐ)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Margin="0,0,0,24" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <Button Content="HỦY" Click="Cancel_Click" Margin="0,0,12,0" 
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#64748B"/>
                <Button Content="LƯU THAY ĐỔI" Click="Save_Click" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="Bold"
                        Height="40" Padding="20,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
