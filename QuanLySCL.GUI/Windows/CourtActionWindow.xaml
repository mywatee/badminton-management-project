<Window x:Class="QuanLySCL.GUI.Windows.CourtActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thao tác nhanh" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>
        
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Thao tác nhanh" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock x:Name="txtTitle" Text="Sân số 1 - 15:00" FontSize="13" Foreground="#64748B" Margin="0,4,0,20"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Action Left: Service or Check-in -->
                <Button x:Name="btnLeft" Grid.Column="0" Click="Service_Click" Height="Auto" Padding="0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border Background="#F0FDF4" BorderBrush="#A3E635" BorderThickness="1" CornerRadius="12" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon x:Name="iconLeft" Kind="BeerOutline" Width="28" Height="28" HorizontalAlignment="Center" Foreground="#166534" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtLeft" Text="DỊCH VỤ" HorizontalAlignment="Center" Foreground="#166534" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Action Right: Check-out or Cancel -->
                <Button x:Name="btnRight" Grid.Column="2" Click="CheckOut_Click" Height="Auto" Padding="0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Cursor="Hand">
                    <Border Background="#FDF2F2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="12" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <materialDesign:PackIcon x:Name="iconRight" Kind="ReceiptTextCheckOutline" Width="28" Height="28" HorizontalAlignment="Center" Foreground="#991B1B" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtRight" Text="THANH TOÁN" HorizontalAlignment="Center" Foreground="#991B1B" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>
            
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource MaterialDesignFlatButton}" Padding="4" Height="24" Width="24" Click="Cancel_Click">
                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="#94A3B8"/>
            </Button>
        </Grid>
    </Border>
</Window>
