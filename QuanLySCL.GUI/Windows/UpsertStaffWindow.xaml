<Window x:Class="QuanLySCL.GUI.Windows.UpsertStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Nhân viên"
        Width="520" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{Binding HeaderText}" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding StaffId}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBox Text="{Binding StaffName, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Họ tên"
                         Margin="0,0,0,12"/>

                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Số điện thoại"
                         Margin="0,0,0,12"/>

                <TextBox Text="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Vị trí (VD: Lễ tân/Thu ngân/Kỹ thuật)"
                         Margin="0,0,0,12"/>

                <TextBlock Text="{Binding ErrorText}" Foreground="#EF4444" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="Lưu" Style="{StaticResource LimeButton}" Width="90" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
