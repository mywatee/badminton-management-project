<Window x:Class="QuanLySCL.GUI.Windows.CustomerDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Chi tiết khách hàng"
        Width="980"
        Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding Customer.Name}" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="{Binding Customer.Id}" Foreground="#64748B"/>
                        <TextBlock Text="  •  " Foreground="#CBD5E1"/>
                        <TextBlock Text="{Binding Customer.Phone}" Foreground="#64748B"/>
                        <TextBlock Text="  •  " Foreground="#CBD5E1"/>
                        <TextBlock Text="{Binding Customer.Email}" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Customer.Status, StringFormat=Rank: {0}}" Foreground="#0F172A" FontWeight="SemiBold"/>
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding Customer.RankProgress}" Height="8" Margin="0,6,0,0"
                                     Background="#E2E8F0" Foreground="#84CC16"/>
                        <TextBlock Text="{Binding Customer.NextRank, StringFormat=Mục tiêu: {0}}" Foreground="#64748B" FontSize="12" Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Customer.NextRank}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Background="#DBEAFE" CornerRadius="10" Padding="10,6" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Số lượt đặt" FontSize="12" Foreground="#1E40AF"/>
                            <TextBlock Text="{Binding TotalBookings}" FontSize="16" FontWeight="SemiBold" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#ECFCCB" CornerRadius="10" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Tổng chi tiêu" FontSize="12" Foreground="#3F6212"/>
                            <TextBlock Text="{Binding TotalSpent, StringFormat='₫{0:N0}'}" FontSize="16" FontWeight="SemiBold" Foreground="#3F6212"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Lịch sử đặt sân" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                    <Button Grid.Column="1" Content="Đóng" Style="{StaticResource OutlineButton}" Padding="16,6" Click="Close_Click"/>
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding VisibleBookings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          AlternatingRowBackground="#F8FAFC"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã đặt" Binding="{Binding Id}" Width="*"/>
                        <DataGridTextColumn Header="Sân" Binding="{Binding Court}" Width="120"/>
                        <DataGridTextColumn Header="Ngày" Binding="{Binding Date, StringFormat='dd/MM/yyyy'}" Width="110"/>
                        <DataGridTextColumn Header="Giờ" Binding="{Binding Time}" Width="110"/>
                        <DataGridTextColumn Header="Loại" Binding="{Binding Type}" Width="90"/>
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Số tiền" Binding="{Binding Amount, StringFormat='₫{0:N0}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2"
                        Content="Xem thêm"
                        HorizontalAlignment="Center"
                        Padding="16,8"
                        Margin="0,16,0,16"
                        Click="LoadMore_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanLoadMore}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
