<Window x:Class="QuanLySCL.GUI.Windows.SuccessDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thành công" Height="220" Width="350" 
        WindowStartupLocation="CenterScreen" AllowsTransparency="True" 
        WindowStyle="None" Background="Transparent" Topmost="True">

    <Border CornerRadius="20" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" Margin="20">
            <TextBlock Text="✅" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="ĐĂNG KÝ THÀNH CÔNG!" FontWeight="Black" Foreground="#2ecc71" HorizontalAlignment="Center" FontSize="16"/>

            <TextBlock x:Name="txtMaKH" Text="Mã khách hàng: KH001" Foreground="#636e72" HorizontalAlignment="Center" Margin="0,5,0,20"/>

            <Button x:Name="btnConfirm" 
                    Content="ĐĂNG NHẬP NGAY" 
                    Height="45" 
                    Width="200"
                    Background="#2ecc71" 
                    Foreground="White" 
                    FontWeight="Bold"
                    FontSize="14"
                    VerticalContentAlignment="Center" 
                    Padding="0"
                    Cursor="Hand"
                    Click="btnConfirm_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="22"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>