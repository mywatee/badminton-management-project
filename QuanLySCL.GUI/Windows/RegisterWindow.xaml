<Window x:Class="QuanLySCL.GUI.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Đăng Ký Thành Viên" Height="700" Width="420"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1"/>
        </Border.Effect>

        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
                <StackPanel Margin="30,10,30,30">
                    <!-- Header -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,10,0,20">
                        <Border Width="60" Height="60" Background="#0984e3" CornerRadius="15">
                            <md:PackIcon Kind="AccountPlus" Width="32" Height="32" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ĐĂNG KÝ THÀNH VIÊN" FontSize="20" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                        <TextBlock Text="Gia nhập cộng đồng The Champions" Foreground="#64748B" HorizontalAlignment="Center" FontSize="12"/>
                    </StackPanel>

                    <!-- Alert Box -->
                    <Border x:Name="brdAlert" Background="#FEE2E2" CornerRadius="8" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚠️" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtAlert" Grid.Column="1" Text="Lỗi thông báo" FontSize="12" Foreground="#EF4444" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Form Fields -->
                    <StackPanel x:Name="stkForm">
                        <TextBlock Text="Họ và Tên" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtFullName" Style="{StaticResource MaterialDesignFloatingHintTextBox}" md:HintAssist.Hint="Nhập họ tên đầy đủ" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPhone" Style="{StaticResource MaterialDesignFloatingHintTextBox}" md:HintAssist.Hint="Ví dụ: 0901234567" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Text="Gmail" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtEmail" Style="{StaticResource MaterialDesignFloatingHintTextBox}" md:HintAssist.Hint="example@gmail.com" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Text="Tên đăng nhập" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtUsername" Style="{StaticResource MaterialDesignFloatingHintTextBox}" md:HintAssist.Hint="Chọn tên đăng nhập" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtPassword" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" md:HintAssist.Hint="Ít nhất 6 ký tự" FontSize="14" Margin="0,0,0,15"/>

                        <TextBlock Text="Xác nhận mật khẩu" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtConfirmPass" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" md:HintAssist.Hint="Nhập lại mật khẩu" FontSize="14" Margin="0,0,0,25"/>

                        <Button x:Name="btnRegister" Content="ĐĂNG KÝ NGAY" Background="#10b981" Foreground="White" FontWeight="Bold" Height="45" FontSize="15"
                                Click="btnRegister_Click" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <!-- OTP Verification Panel -->
                    <StackPanel x:Name="stkOTP" Visibility="Collapsed">
                        <TextBlock Text="Xác thực Email (via Brevo)" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Chúng tôi đã gửi mã OTP đến Gmail của bạn qua hệ thống REST API. Vui lòng nhập mã để hoàn tất." 
                                   TextWrapping="Wrap" TextAlignment="Center" Foreground="#64748B" FontSize="13" Margin="0,0,0,20"/>
                        
                        <TextBox x:Name="txtOTP" Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                                 md:HintAssist.Hint="Nhập mã OTP 6 số" FontSize="18" FontWeight="Bold" 
                                 HorizontalContentAlignment="Center" Margin="0,0,0,20"/>

                        <Button x:Name="btnVerifyOTP" Content="XÁC NHẬN" Background="#0984e3" Foreground="White" FontWeight="Bold" Height="45" FontSize="15"
                                Click="btnVerifyOTP_Click" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <Button Content="Quay lại" Background="Transparent" BorderThickness="0" Foreground="#64748B" Margin="0,10,0,0"
                                Click="btnBackToForm_Click"/>
                    </StackPanel>

                    <TextBlock HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Run Text="Đã có tài khoản? " Foreground="#64748B"/>
                        <Hyperlink Click="btnGoToLogin_Click" 
                                   Foreground="#0984e3" 
                                   FontWeight="Bold" 
                                   TextDecorations="None">
                            Đăng nhập ngay
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>

            <!-- Nút đóng -->
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15"
                    Width="30" Height="30" Background="Transparent" BorderThickness="0"
                    Foreground="Black" FontSize="14" Cursor="Hand" Click="btnClose_Click" Panel.ZIndex="10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>