<Window x:Class="QuanLySCL.GUI.Windows.UpsertServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dịch vụ"
        Width="520"
        Height="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#0F172A"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Mã dịch vụ" Foreground="#64748B"/>
                <TextBox Grid.Row="1"
                         Text="{Binding ServiceId}"
                         IsReadOnly="True"
                         Background="#F1F5F9"
                         BorderBrush="#CBD5E1"
                         Margin="0,6,0,12"/>

                <TextBlock Grid.Row="2" Text="Tên dịch vụ" Foreground="#64748B"/>
                <TextBox Grid.Row="3"
                         Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}"
                         BorderBrush="#CBD5E1"
                         Margin="0,6,0,12"/>

                <Grid Grid.Row="4" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Nhóm" Foreground="#64748B"/>
                        <ComboBox ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  BorderBrush="#CBD5E1"
                                  Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Đơn vị" Foreground="#64748B"/>
                        <TextBox Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                 BorderBrush="#CBD5E1"
                                 Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="5" Text="Giá hiện hành" Foreground="#64748B"/>
                <TextBox Grid.Row="6"
                         Text="{Binding PriceText, UpdateSourceTrigger=PropertyChanged}"
                         BorderBrush="#CBD5E1"
                         Margin="0,6,0,12"/>

                <Grid Grid.Row="7" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tồn kho" Foreground="#64748B"/>
                        <TextBox Text="{Binding StockText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderBrush="#CBD5E1"
                                 Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Gợi ý" Foreground="#64748B"/>
                        <TextBlock Text="0 nếu không quản lý kho"
                                   Foreground="#94A3B8"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="8"
                           Text="{Binding ErrorText}"
                           Foreground="#DC2626"
                           TextWrapping="Wrap"
                           Margin="0,0,0,6"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Hủy" Padding="14,8" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#E2E8F0" BorderBrush="#CBD5E1" Foreground="#0F172A"/>
            <Button Content="Lưu" Padding="18,8" Click="Save_Click"
                    Background="{StaticResource LimeGreen}" BorderBrush="{StaticResource LimeGreen}" Foreground="#0F172A"/>
        </StackPanel>
    </Grid>
</Window>
