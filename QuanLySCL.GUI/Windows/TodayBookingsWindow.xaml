<Window x:Class="QuanLySCL.GUI.Windows.TodayBookingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Danh sách lịch đặt trong ngày" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="LỊCH ĐẶT TRONG NGÀY" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Danh sách chi tiết tất cả các ca đặt sân phục vụ ngày hôm nay." FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="1" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgBookings" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      BorderThickness="0"
                      Background="Transparent"
                      HeadersVisibility="Column"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFC"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E2E8F0"
                      RowHeight="56"
                      ColumnHeaderHeight="48"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#64748B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã hóa đơn" Binding="{Binding Id}" Width="120" Foreground="#6366F1"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding Customer}" Width="*"/>
                    <DataGridTextColumn Header="Loại đặt" Binding="{Binding Type}" Width="150"/>
                    <DataGridTextColumn Header="Sân cầu" Binding="{Binding Court}" Width="150"/>
                    <DataGridTextColumn Header="Ca Giờ" Binding="{Binding Time}" Width="150" FontWeight="Bold"/>
                    
                    <DataGridTemplateColumn Header="Trạng thái" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="12,6" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Foreground" Value="#D97706"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                        <Setter Property="Foreground" Value="#059669"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#475569"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Đóng cửa sổ" IsCancel="True" Click="Close_Click"
                    Style="{DynamicResource MaterialDesignOutlinedButton}"
                    Foreground="#64748B" BorderBrush="#CBD5E1"
                    Width="120" Height="40" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
