<Window x:Class="QuanLySCL.GUI.Windows.ServiceSaleDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chi tiết hóa đơn dịch vụ"
        Width="820"
        Height="560"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Chi tiết hóa đơn" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding HeaderLine}" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding CustomerLine}" Foreground="#0F172A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PaymentLine}" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding IssuedAtLine}" Foreground="#64748B" HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding InvoiceIdLine}" Foreground="#0F172A" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Dịch vụ" Binding="{Binding ServiceName}" Width="*"/>
                        <DataGridTextColumn Header="Số lượng" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=đ{0:N0}}" Width="120"/>
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding Total, StringFormat=đ{0:N0}}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Tạm tính" Foreground="#64748B"/>
                    <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat=đ{0:N0}}" Foreground="#0F172A"/>

                    <TextBlock Grid.Row="1" Text="Giảm giá" Foreground="#64748B" Margin="0,6,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Discount, StringFormat=-đ{0:N0}}" Foreground="#EF4444" Margin="0,6,0,0"/>

                    <TextBlock Grid.Row="2" Text="Tổng cộng" FontWeight="Bold" FontSize="16" Foreground="#0F172A" Margin="0,10,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalPayable, StringFormat=đ{0:N0}}" FontWeight="Bold" FontSize="16" Foreground="#0F172A" Margin="0,10,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Đóng" Width="110" Height="34" Click="Close_Click" Style="{StaticResource OutlineButton}"/>
        </StackPanel>
    </Grid>
</Window>

