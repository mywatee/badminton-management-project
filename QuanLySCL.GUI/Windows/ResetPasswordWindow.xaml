<Window x:Class="QuanLySCL.GUI.Windows.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Reset mật khẩu"
        Width="480" Height="320"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Reset mật khẩu" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding Username}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <PasswordBox x:Name="PasswordBox"
                         materialDesign:HintAssist.Hint="Mật khẩu mới"
                         Margin="0,0,0,12"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         materialDesign:HintAssist.Hint="Nhập lại mật khẩu"
                         Margin="0,0,0,12"/>
            <TextBlock Text="{Binding ErrorText}" Foreground="#EF4444" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Hủy" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,12,0" Click="Cancel_Click"/>
            <Button Content="Xác nhận" Style="{StaticResource LimeButton}" Width="110" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>

