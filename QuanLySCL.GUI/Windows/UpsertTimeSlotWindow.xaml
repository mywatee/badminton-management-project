<Window x:Class="QuanLySCL.GUI.Windows.UpsertTimeSlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thông tin Ca giờ" Height="360" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">
    
    <Border BorderBrush="{StaticResource NavyBlueLight}" BorderThickness="0" Background="White" CornerRadius="12">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,24">
                <Grid>
                    <materialDesign:PackIcon Kind="ClockEditOutline" Width="24" Height="24" Foreground="{StaticResource LimeGreen}" VerticalAlignment="Center"/>
                    <TextBlock Text="Thông tin Ca giờ" FontSize="22" FontWeight="Bold" Foreground="{StaticResource NavyBlueBrush}" Margin="32,0,0,0"/>
                </Grid>
                <Separator Background="#F1F5F9" Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <TextBox x:Name="TxtId" 
                         materialDesign:HintAssist.Hint="Mã ca (ví dụ: C10)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,16"/>

                <TextBox x:Name="TxtName" 
                         materialDesign:HintAssist.Hint="Tên ca (ví dụ: Ca sáng 1)"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtStart" Grid.Column="0" Margin="0,0,8,0"
                             materialDesign:HintAssist.Hint="Giờ bắt đầu (hh:mm)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    <TextBox x:Name="TxtEnd" Grid.Column="1" Margin="8,0,0,0"
                             materialDesign:HintAssist.Hint="Giờ kết thúc (hh:mm)"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                </Grid>

                <CheckBox x:Name="ChkVang" Content="Khung giờ vàng (Peak Hour)" 
                          Style="{StaticResource MaterialDesignCheckBox}"
                          Foreground="{StaticResource NavyBlueLight}" FontWeight="SemiBold"
                          IsChecked="False"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="HỦY" Click="Cancel_Click" Margin="0,0,12,0" 
                        Style="{StaticResource MaterialDesignFlatButton}" Foreground="#64748B"/>
                <Button Content="LƯU THAY ĐỔI" Click="Save_Click" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="Bold"
                        Height="40" Padding="20,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
