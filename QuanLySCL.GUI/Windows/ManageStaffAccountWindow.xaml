<Window x:Class="QuanLySCL.GUI.Windows.ManageStaffAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Quản lý tài khoản"
        Width="560" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Quản lý tài khoản nhân viên" FontSize="20" FontWeight="SemiBold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding StaffSummary}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Tên đăng nhập"
                     Margin="0,0,0,12"/>

            <ComboBox ItemsSource="{Binding RoleOptions}"
                      SelectedItem="{Binding SelectedRole}"
                      materialDesign:HintAssist.Hint="Quyền"
                      Margin="0,0,0,12"/>

            <CheckBox IsChecked="{Binding AccountIsActive}" Content="Kích hoạt tài khoản" Margin="0,0,0,12"/>

            <TextBlock Text="{Binding ErrorText}" Foreground="#EF4444" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Xóa tài khoản" Style="{StaticResource RedButton}" Click="Delete_Click" />
            <Button Grid.Column="1" Content="Hủy" Style="{StaticResource OutlineButton}" Width="90" Margin="12,0,12,0" Click="Cancel_Click"/>
            <Button Grid.Column="2" Content="Lưu" Style="{StaticResource LimeButton}" Width="90" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>

