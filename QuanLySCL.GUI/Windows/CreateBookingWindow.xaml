<Window x:Class="QuanLySCL.GUI.Windows.CreateBookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:QuanLySCL.GUI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Đặt sân mới"
        Height="720"
        Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">

    <Window.Resources>
        <local:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:InverseBooleanConverter x:Key="InvBool"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Đặt sân mới" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Chọn ngày, ca giờ, sân và khách hàng. Hệ thống sẽ tự kiểm tra trùng lịch." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Ngày sử dụng" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding UsageDate, UpdateSourceTrigger=PropertyChanged}"
                                        DisplayDateStart="{x:Static sys:DateTime.Today}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Loại đặt" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <ComboBox x:Name="TypeCombo" SelectedValue="{Binding BookingTypeVN}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Lẻ" Tag="Lẻ"/>
                                <ComboBoxItem Content="Cố định" Tag="Cố định"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Repetition Field (Only for Fixed) -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BookingTypeVN}" Value="Cố định">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Số buổi lặp lại (hàng tuần)" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NumberOfWeeks, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Nhập số buổi (ví dụ: 4)"/>
                            <TextBlock Grid.Column="1" Text="Buổi" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#64748B"/>
                        </Grid>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Sân" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Courts}" SelectedItem="{Binding SelectedCourt}" DisplayMemberPath="Name"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Ca giờ" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TimeSlots}" SelectedItem="{Binding SelectedSlot}" DisplayMemberPath="DisplayLabel"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Giá tiền sân dự kiến" FontSize="12" Foreground="#64748B"/>
                                <TextBlock Text="{Binding Price, StringFormat='₫{0:N0}'}" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Price}" Value="0">
                                                    <Setter Property="Foreground" Value="#B91C1C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Nếu bảng giá trống, hệ thống sẽ dùng 0." FontSize="11" Foreground="#94A3B8" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#ECFCCB" CornerRadius="10" Padding="10,8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cash" Width="18" Height="18" Foreground="#3F6212" Margin="0,0,8,0"/>
                                    <TextBlock Text="Tự tính" FontWeight="SemiBold" Foreground="#3F6212"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Price Warning (Step 5) -->
                    <Border Background="#FEF2F2" BorderBrush="#FEE2E2" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Price}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="#B91C1C" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Chưa có thông tin giá cho khung giờ này. Vui lòng cập nhật bảng giá." Foreground="#B91C1C" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Service Selection (Step 4) -->
                    <Expander Header="Dịch vụ đi kèm (Nước, Thuê vợt...)" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,14" IsExpanded="True">
                        <StackPanel Margin="10,5">
                            <ItemsControl ItemsSource="{Binding AvailableServices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Service.Name}" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding Service.Price, StringFormat='₫{0:N0}'}" FontSize="11" Foreground="#64748B"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="Số lượng:" FontSize="12" VerticalAlignment="Center" Foreground="#64748B" Margin="0,0,8,0"/>
                                                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="40" TextAlignment="Center" materialDesign:HintAssist.Hint="0"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat='₫{0:N0}'}" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center" TextAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <TextBlock Text="Khách hàng" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,14" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Chọn khách có sẵn (tùy chọn)" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                        <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="Name"/>
                        <TextBlock Text="Hoặc nhập nhanh để tạo mới" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Họ tên" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsAdminOrStaff, Converter={StaticResource InvBool}}" Background="{Binding IsAdminOrStaff, Converter={StaticResource InvBoolToVis}, ConverterParameter='Background'}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminOrStaff}" Value="False">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Số điện thoại" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsAdminOrStaff, Converter={StaticResource InvBool}}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAdminOrStaff}" Value="False">
                                                <Setter Property="Background" Value="#F1F5F9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="Email (tùy chọn)" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                        <TextBox Text="{Binding CustomerEmail, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsAdminOrStaff, Converter={StaticResource InvBool}}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAdminOrStaff}" Value="False">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>

                    <Border Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Visibility="{Binding ErrorText, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorText}" Foreground="#B91C1C"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="14" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tổng cộng (Sân + Dịch vụ):" FontSize="11" Foreground="#64748B"/>
                    <TextBlock Text="{Binding TotalPrice, StringFormat='₫{0:N0}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource LimeGreen}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Hủy" Click="Cancel_Click" Padding="16,8" Margin="0,0,10,0" Background="#E2E8F0" BorderBrush="#CBD5E1" Foreground="#0F172A" Cursor="Hand"/>
                <Button Grid.Column="2" Content="Lưu" Click="Save_Click" Padding="18,8" Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
