<Window x:Class="QuanLySCL.GUI.Windows.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Khôi Phục Mật Khẩu" Height="550" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="20" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1"/>
        </Border.Effect>

        <Grid Margin="30">
            <StackPanel>
                <!-- Header -->
                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,20">
                    <Border Width="60" Height="60" Background="#f59e0b" CornerRadius="15">
                        <md:PackIcon Kind="KeyChange" Width="32" Height="32" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="KHÔI PHỤC MẬT KHẨU" FontSize="18" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center" Margin="0,10,0,5"/>
                    <TextBlock Text="Làm theo hướng dẫn để đặt lại mật khẩu" Foreground="#64748B" HorizontalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <!-- Alert -->
                <Border x:Name="brdAlert" Background="#FEE2E2" CornerRadius="8" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
                    <TextBlock x:Name="txtAlert" Text="Thông báo lỗi" FontSize="12" Foreground="#EF4444" TextWrapping="Wrap"/>
                </Border>

                <!-- Bước 1: Nhập Email -->
                <StackPanel x:Name="step1_Panel">
                    <TextBlock Text="Hãy nhập email bạn đăng ký:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,10"/>
                    <TextBox x:Name="txtInfo" Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                             md:HintAssist.Hint="example@gmail.com" FontSize="14" Margin="0,0,0,20"/>

                    <Button x:Name="btnSendOTP" Content="XÁC NHẬN" Background="#0984e3" Foreground="White" FontWeight="Bold" Height="45"
                            Click="btnSendOTP_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Bước 2: Nhập OTP -->
                <StackPanel x:Name="step2_Panel" Visibility="Collapsed">
                    <TextBlock Text="Mã OTP đã được gửi! Vui lòng kiểm tra." Foreground="#059669" FontWeight="SemiBold" Margin="0,0,0,15" TextAlignment="Center"/>
                    <TextBlock Text="Nhập mã OTP (6 số):" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtOTP" Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="16" FontWeight="Bold" TextAlignment="Center" MaxLength="6" Margin="0,0,0,20"/>

                    <Button Content="XÁC NHẬN MÃ" Background="#10b981" Foreground="White" FontWeight="Bold" Height="45"
                            Click="btnVerifyOTP_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Bước 3: Đổi mật khẩu -->
                <StackPanel x:Name="step3_Panel" Visibility="Collapsed">
                    <Separator Margin="0,0,0,20" Background="#E2E8F0"/>
                    <TextBlock Text="Đặt mật khẩu mới:" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtNewPass" Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" FontSize="14" Margin="0,0,0,20"/>

                    <Button Content="ĐỔI MẬT KHẨU" Background="#f59e0b" Foreground="White" FontWeight="Bold" Height="45"
                            Click="btnUpdatePassword_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <!-- Quay lại -->
                <Button Content="Quay lại Đăng nhập" Background="Transparent" BorderThickness="0" Foreground="#64748B" 
                        Margin="0,20,0,0" Cursor="Hand" Click="btnClose_Click" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Nút đóng -->
            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-15,-15,-15,0"
                    Width="30" Height="30" Background="Transparent" BorderThickness="0"
                    Foreground="Black" FontSize="14" Cursor="Hand" Click="btnClose_Click" Panel.ZIndex="10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>