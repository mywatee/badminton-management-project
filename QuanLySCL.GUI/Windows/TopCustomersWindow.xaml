<Window x:Class="QuanLySCL.GUI.Windows.TopCustomersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Top khách hàng"
        Width="820"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundGray}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Khách hàng hàng đầu" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Top 20 theo tổng chi tiêu" FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Đóng" Style="{StaticResource OutlineButton}" Padding="16,6" Click="Close_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F8FAFC"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã KH" Binding="{Binding CustomerId}" Width="110"/>
                    <DataGridTextColumn Header="Tên khách" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Lượt đặt" Binding="{Binding TotalBookings}" Width="90"/>
                    <DataGridTextColumn Header="Tổng chi" Binding="{Binding TotalSpent, StringFormat='₫{0:N0}'}" Width="130"/>
                    <DataGridTemplateColumn Header="Chi tiết" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Xem"
                                        Padding="10,6"
                                        MinWidth="70"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Tag="{Binding CustomerId}"
                                        Click="ViewCustomer_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>

