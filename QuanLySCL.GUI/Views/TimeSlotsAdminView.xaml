<Page x:Class="QuanLySCL.GUI.Views.TimeSlotsAdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLySCL.GUI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Quản lý Ca giờ">

    <Grid Background="{StaticResource BackgroundGray}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <!-- Header Section -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Quản lý Ca giờ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource NavyBlueBrush}"/>
                        <TextBlock Text="Thiết lập các khung giờ hoạt động và xác định giờ cao điểm" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Click="Reload_Click" ToolTip="Tải lại dữ liệu"
                                Style="{StaticResource MaterialDesignIconButton}" Foreground="#64748B" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Refresh" />
                        </Button>
                        <Button Click="Add_Click" Content="THÊM CA MỚI" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="Bold" Height="40" Padding="16,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Data Card -->
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <StackPanel>
                        <!-- Inline Action Bar -->
                        <Border Background="#F1F5F9" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Danh sách các ca" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Click="Edit_Click" Content="Sửa" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"
                                            BorderBrush="#93C5FD" Foreground="#1E40AF"/>
                                    <Button Click="Delete_Click" Content="Xóa" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"
                                            BorderBrush="#FCA5A5" Foreground="#991B1B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding TimeSlots}"
                                  SelectedItem="{Binding SelectedSlot}"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Height" Value="45"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                </Style>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                    <Setter Property="Padding" Value="16,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã ca" Binding="{Binding Id}" Width="100"/>
                                <DataGridTextColumn Header="Tên ca" Binding="{Binding Name}" Width="*"/>
                                
                                <DataGridTemplateColumn Header="Thời gian" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ClockOutline" VerticalAlignment="Center" Width="14" Height="14" Foreground="#64748B" Margin="0,0,6,0"/>
                                                <TextBlock Text="{Binding DisplayLabel}" VerticalAlignment="Center" FontWeight="Medium"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Phân loại" Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LaKhungGioVang}" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon x:Name="Icon" Kind="StarCircleOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" Visibility="Collapsed"/>
                                                    <TextBlock x:Name="Text" Text="Thường" FontSize="11" FontWeight="SemiBold" Foreground="#64748B"/>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding LaKhungGioVang}" Value="True">
                                                    <Setter TargetName="Text" Property="Text" Value="GIỜ VÀNG"/>
                                                    <Setter TargetName="Text" Property="Foreground" Value="#92400E"/>
                                                    <Setter TargetName="Icon" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="Icon" Property="Foreground" Value="#D97706"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
