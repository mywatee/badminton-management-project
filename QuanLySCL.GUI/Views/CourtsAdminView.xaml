<Page x:Class="QuanLySCL.GUI.Views.CourtsAdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1080"
      Title="Quản lý sân">

    <Grid Background="{StaticResource BackgroundGray}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <!-- Header Section -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Quản lý hệ thống Sân" FontSize="28" FontWeight="Bold" Foreground="{StaticResource NavyBlueBrush}"/>
                        <TextBlock Text="Thêm, sửa, xóa và theo dõi trạng thái hoạt động của các sân cầu lông" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Click="Reload_Click" ToolTip="Tải lại dữ liệu"
                                Style="{StaticResource MaterialDesignIconButton}" Foreground="#64748B" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Refresh" />
                        </Button>
                        <Button Click="Add_Click" Content="THÊM SÂN MỚI" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="Bold" Height="40" Padding="16,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Data Card -->
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <StackPanel>
                        <!-- Inline Action Bar -->
                        <Border Background="#F1F5F9" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Danh sách các sân" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Click="Edit_Click" Content="Sửa" Margin="0,0,8,0"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"
                                            BorderBrush="#93C5FD" Foreground="#1E40AF"/>
                                    <Button Click="Delete_Click" Content="Xóa" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="32" Padding="12,0"
                                            BorderBrush="#FCA5A5" Foreground="#991B1B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid ItemsSource="{Binding Courts}"
                                  SelectedItem="{Binding SelectedCourt}"
                                  HeadersVisibility="Column"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  BorderThickness="0"
                                  Background="Transparent">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Height" Value="45"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                </Style>
                                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                    <Setter Property="Padding" Value="16,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Mã sân" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="40" Height="24" Background="#0F172A" CornerRadius="4">
                                                <TextBlock Text="{Binding Id}" FontSize="12" FontWeight="Bold" Foreground="#84CC16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Tên sân" Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Loại sân" Binding="{Binding Type}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Trạng thái" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="12,4" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                <Setter Property="Background" Value="#ECFCCB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="In-use">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                <Setter Property="Background" Value="#FED7AA"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                    <Setter Property="Foreground" Value="#4D7C0F"/>
                                                                    <Setter Property="Text" Value="SẴN SÀNG"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="In-use">
                                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                                    <Setter Property="Text" Value="ĐANG SỬ DỤNG"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                    <Setter Property="Foreground" Value="#C2410C"/>
                                                                    <Setter Property="Text" Value="BẢO TRÌ"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
