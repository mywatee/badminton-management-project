<Page x:Class="QuanLySCL.GUI.Views.PricingAdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:QuanLySCL.GUI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1080"
      Title="Quản lý Bảng giá">
    
    <Grid Background="{StaticResource BackgroundGray}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">
                <!-- Header Section -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Cấu hình Bảng giá" FontSize="28" FontWeight="Bold" Foreground="{StaticResource NavyBlueBrush}"/>
                        <TextBlock Text="Quản lý đơn giá thuê sân. Tối ưu theo từng ca giờ và loại hình đặt" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Click="Reload_Click" ToolTip="Tải lại dữ liệu"
                                Style="{StaticResource MaterialDesignIconButton}" Foreground="#64748B" Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="Refresh" />
                        </Button>
                        <Button Click="Add_Click" Content="THÊM MỚI" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="{StaticResource LimeGreen}" Foreground="#0F172A" FontWeight="Bold" Height="40" Padding="16,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Tabs & Data Card -->
                <Border Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                    <TabControl ItemsSource="{Binding CourtTypes}" 
                                SelectedItem="{Binding SelectedCourtType}"
                                BorderThickness="0"
                                Background="Transparent"
                                Style="{StaticResource MaterialDesignTabControl}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="4,2"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Inline Action Bar -->
                                    <Border Background="#F1F5F9" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Text="Danh sách giá theo ca giờ" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#475569"/>
                                        </Grid>
                                    </Border>

                                    <!-- Filtered DataGrid -->
                                    <DataGrid ItemsSource="{Binding DataContext.FilteredEntries, RelativeSource={RelativeSource AncestorType=Page}}"
                                              SelectedItem="{Binding DataContext.SelectedEntry, RelativeSource={RelativeSource AncestorType=Page}}"
                                              HeadersVisibility="Column"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              Background="Transparent">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                <Setter Property="Height" Value="45"/>
                                                <Setter Property="Padding" Value="16,0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                                <Setter Property="Padding" Value="16,12"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Setter Property="Foreground" Value="Black"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Ca giờ" Width="2*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="ClockOutline" Width="16" Height="16" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding SlotName}" VerticalAlignment="Center" FontWeight="Medium"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            
                                            <DataGridTemplateColumn Header="Giá Lẻ" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left" Background="#E0F2FE">
                                                            <TextBlock Text="{Binding PriceLe, StringFormat='₫{0:N0}'}" FontSize="12" FontWeight="SemiBold" Foreground="#0369A1"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Giá Cố định" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="12" Padding="8,2" HorizontalAlignment="Left" Background="#DCFCE7">
                                                            <TextBlock Text="{Binding PriceFixed, StringFormat='₫{0:N0}'}" FontSize="12" FontWeight="SemiBold" Foreground="#15803D"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Thao tác" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button Click="Edit_Click" ToolTip="Sửa giá"
                                                                    Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32">
                                                                <materialDesign:PackIcon Kind="PencilOutline" Width="18" Height="18" Foreground="#64748B"/>
                                                            </Button>
                                                            <Button Click="Delete_Click" ToolTip="Xóa giá"
                                                                    Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" Margin="4,0,0,0">
                                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18" Foreground="#F87171"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
