<Page x:Class="QuanLySCL.GUI.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:conv="clr-namespace:QuanLySCL.GUI.Converters"
      Title="Tổng quan">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NumericToVisibilityConverter x:Key="NumToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tổng quan" FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="{Binding WelcomeMessage}" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Quick Search Bar (For Staff) -->
                <Grid Grid.Column="1" VerticalAlignment="Center"
                      Visibility="{Binding IsAdminOrStaff, Converter={StaticResource BoolToVis}}">
                    <Border x:Name="QuickSearchBorder" Background="White" CornerRadius="12" Padding="12,4"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="Magnify" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="QuickSearchBox"
                                     Grid.Column="1"
                                     Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Tìm khách thanh toán (SĐT/Tên)..."
                                     BorderThickness="0"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     KeyDown="QuickSearchBox_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Suggestion popup: choose booking to check-out -->
                    <Popup x:Name="QuickSearchPopup"
                           PlacementTarget="{Binding ElementName=QuickSearchBorder}"
                           Placement="Bottom"
                           StaysOpen="True"
                           AllowsTransparency="True"
                           IsOpen="{Binding IsQuickSearchPopupOpen}">
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12"
                                Margin="0,6,0,0" Padding="8" Width="{Binding ElementName=QuickSearchBorder, Path=ActualWidth}">
                            <StackPanel>
                                <TextBlock Text="Chọn lượt đặt để thanh toán" Foreground="#64748B" FontSize="12" Margin="4,2,4,6"/>
                                <ListBox x:Name="QuickSearchList"
                                         ItemsSource="{Binding QuickSearchMatches}"
                                         SelectedItem="{Binding SelectedQuickSearchMatch}"
                                         MaxHeight="240"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MouseDoubleClick="QuickSearchList_MouseDoubleClick"
                                         KeyDown="QuickSearchList_KeyDown">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Customer}" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding Phone}" Foreground="#64748B" FontSize="12"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding Court}" Foreground="#0F172A" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding Time}" Foreground="#64748B" FontSize="12" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="Enter để thanh toán, Esc để đóng" Foreground="#94A3B8" FontSize="11" Margin="4,6,4,2"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <!-- Stats Cards - ADMIN VERSION -->
            <Grid Margin="0,0,0,24" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Daily Revenue -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Doanh thu hôm nay" FontSize="13" Foreground="#64748B"/>
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Width="48" Height="48" Background="#10B981" CornerRadius="8" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="CurrencyUsd" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DailyRevenue, StringFormat='₫{0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- Active Bookings -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Số lượt đặt đang hoạt động" FontSize="13" Foreground="#64748B"/>
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Width="48" Height="48" Background="#3B82F6" CornerRadius="8" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="Calendar" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ActiveBookings}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- Total Customers -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tổng số khách hàng" FontSize="13" Foreground="#64748B"/>
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Width="48" Height="48" Background="#8B5CF6" CornerRadius="8" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding TotalCustomers}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- Monthly Growth -->
                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="12,0,0,0" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tăng trưởng tháng" FontSize="13" Foreground="#64748B"/>
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Width="48" Height="48" Background="#84CC16" CornerRadius="8" VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding MonthlyGrowth, StringFormat='{}{0}%'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Stats Cards - CUSTOMER VERSION -->
            <Grid Margin="0,0,0,24" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource InvBoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Current Rank -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" Background="#f8fafc">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="64" Height="64" CornerRadius="32" Background="White" Margin="0,0,16,0">
                            <materialDesign:PackIcon Kind="TrophyVariant" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserRank}" Value="VIP">
                                                <Setter Property="Foreground" Value="#6366F1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserRank}" Value="Vàng">
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserRank}" Value="Bạc">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserRank}" Value="Thành viên">
                                                <Setter Property="Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Hạng hiện tại" FontSize="14" Foreground="#64748B"/>
                            <TextBlock Text="{Binding UserRank}" FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>

                            <Border Margin="0,10,0,0" Cursor="Hand" MouseLeftButtonUp="RankProgress_Click"
                                    ToolTip="{Binding RankTooltipText}">
                                <Grid>
                                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding RankProgress}" Height="10"
                                                 Background="#E2E8F0" Foreground="#84CC16"/>
                                    <TextBlock Text="{Binding RankPercentText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               Visibility="{Binding IsRankPercentVisible, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding NextRank, StringFormat=Mục tiêu: {0}}" Foreground="#64748B" FontSize="12" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NextRank}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Text="{Binding RankBenefitText}" Foreground="#64748B" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding RankRequirementText}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap"/>

                            <Expander Margin="0,10,0,0">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16" Foreground="#64748B" Margin="0,0,6,0"/>
                                        <TextBlock Text="Ưu đãi theo hạng" Foreground="#0F172A" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Expander.Header>
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="• Thành viên: 0% (chưa áp dụng giảm giá)." Foreground="#334155" FontSize="12"/>
                                        <TextBlock Text="• Bạc: giảm 5% (>= 30 lượt đặt)." Foreground="#334155" FontSize="12" Margin="0,2,0,0"/>
                                        <TextBlock Text="• Vàng: giảm 10% (>= 50 lượt đặt hoặc >= 5.000.000₫)." Foreground="#334155" FontSize="12" Margin="0,2,0,0"/>
                                        <TextBlock Text="• VIP: giảm 15% (>= 100 lượt đặt hoặc >= 10.000.000₫)." Foreground="#334155" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Personal Bookings -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Số lượt đặt" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalPersonalBookings}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Personal Spending -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng chi tiêu" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalPersonalSpent, StringFormat='₫{0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Alerts and Upcoming - ADMIN ONLY -->
            <Grid Margin="0,0,0,24" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Low Stock Alerts -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" 
                        Visibility="{Binding LowStockServices.Count, Converter={StaticResource NumToVis}, FallbackValue=Visible}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="#EF4444" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cảnh báo hết hàng" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding LowStockServices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding Stock, StringFormat='Còn lại: {0}'}" HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" Foreground="#EF4444"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Today's Bookings -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Foreground="#F59E0B" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lịch đặt trong ngày" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OutlineButton}"
                                    Click="ViewTodayBookings_Click"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                Chi tiết
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding TodayBookings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Customer}" FontSize="13" Foreground="#0F172A"/>
                                            <Border CornerRadius="4" Background="#6366F1" Padding="6,2" Margin="8,0,0,0" 
                                                    Visibility="{Binding IsMyBooking, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Của tôi" FontSize="9" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Time}" HorizontalAlignment="Right" FontSize="13" Foreground="#64748B"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Court Status Grid (Visible to all) -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trạng thái sân" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource OutlineButton}"
                                    Click="ViewAllCourts_Click"
                                    Padding="12,6"
                                    VerticalAlignment="Center">
                                Xem tất cả
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Courts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0"
                                            BorderThickness="2"
                                            CornerRadius="8"
                                            Padding="16"
                                            Margin="4"
                                            Background="White"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonUp="CourtCard_MouseLeftButtonUp">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#84CC16"/>
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsMyBooking}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#6366F1"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="10" Color="#6366F1" Opacity="0.2" ShadowDepth="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Width="48" Height="48" Background="#0F172A" CornerRadius="8" Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Id}" FontSize="20" FontWeight="Bold" Foreground="#84CC16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                <Setter Property="Background" Value="#ECFCCB"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="In-use">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMyBooking}" Value="True">
                                                                <Setter Property="Background" Value="#6366F1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                <Setter Property="Background" Value="#FED7AA"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Available">
                                                                    <Setter Property="Foreground" Value="#65A30D"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="In-use">
                                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsMyBooking}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="Text" Value="Tôi dùng"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Maintenance">
                                                                    <Setter Property="Foreground" Value="#C2410C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                             </Border>
                                             
                                             <!-- Service Button for Court Card (Admin/Staff only) -->
                                             <Button x:Name="btnServiceCourt"
                                                     Content="Dịch vụ"
                                                     Click="AddService_Click"
                                                     Tag="{Binding}"
                                                     Foreground="#6366F1" BorderBrush="#6366F1"
                                                     Height="24" Padding="8,0" Margin="0,8,0,0"
                                                     FontSize="9" FontWeight="Bold">
                                                 <Button.Style>
                                                     <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                         <Style.Triggers>
                                                             <MultiDataTrigger>
                                                                 <MultiDataTrigger.Conditions>
                                                                     <Condition Binding="{Binding Status}" Value="In-use"/>
                                                                     <Condition Binding="{Binding DataContext.IsAdminOrStaff, RelativeSource={RelativeSource AncestorType=Page}}" Value="True"/>
                                                                 </MultiDataTrigger.Conditions>
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                             </MultiDataTrigger>
                                                         </Style.Triggers>
                                                     </Style>
                                                 </Button.Style>
                                             </Button>
                                         </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Right Side List -->
                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <!-- Recent Bookings - ADMIN VERSION -->
                    <Border Style="{StaticResource Card}" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lịch đặt gần đây" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource OutlineButton}"
                                        Click="ViewAllBookings_Click"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    Xem tất cả
                                </Button>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RecentBookings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="4,0,0,0" Padding="12,8" Margin="0,0,0,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#84CC16"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMyBooking}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#6366F1"/>
                                                            <Setter Property="Background" Value="#F5F3FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Customer}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <Border CornerRadius="4" Background="#6366F1" Padding="6,2" Margin="8,0,0,0" 
                                                            Visibility="{Binding IsMyBooking, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="Của tôi" FontSize="9" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" CornerRadius="4" Padding="6,3" VerticalAlignment="Top">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Background" Value="#F1F5F9"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                        <Setter Property="Foreground" Value="#475569"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Court}" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Time}" FontSize="11" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                                
                                                <!-- Actions for Admin (Check-in / Service) -->
                                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                                                    <Button Content="Check-in" 
                                                            Padding="8,2" FontSize="10" Height="22" 
                                                            Margin="0,0,8,0"
                                                            Click="CheckIn_Click"
                                                            Tag="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Content="Thanh toán" 
                                                            Padding="8,2" FontSize="10" Height="22"
                                                            Click="CheckOut_Click"
                                                            Tag="{Binding}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource LimeButton}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Personal Booking History - CUSTOMER VERSION -->
                    <Border Style="{StaticResource Card}" Visibility="{Binding IsAdminOrStaff, Converter={StaticResource InvBoolToVis}}">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lịch sử đặt sân của tôi" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                                <Button Grid.Column="1"
                                        Style="{StaticResource OutlineButton}"
                                        Click="ViewAllBookings_Click"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    Chi tiết
                                </Button>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding PersonalBookings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#6366F1" BorderThickness="4,0,0,0" Padding="12,8" Margin="0,0,0,12" Background="#fcfcfd">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Date, StringFormat='dd/MM/yyyy'}" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock Text=" - " Foreground="#94A3B8"/>
                                                    <TextBlock Text="{Binding Time}" FontSize="13" Foreground="#475569"/>
                                                </StackPanel>
                                                
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Court}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                                
                                                <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Background" Value="#f1f5f9"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#fffbea"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                                    <Setter Property="Background" Value="#f0fdf4"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                        <Setter Property="Foreground" Value="#64748b"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#b45309"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Checked-in">
                                                                        <Setter Property="Foreground" Value="#15803d"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <TextBlock Text="Bạn chưa có lượt đặt sân nào." 
                                       FontSize="13" Foreground="#94A3B8" FontStyle="Italic" 
                                       HorizontalAlignment="Center" Margin="0,20"
                                       Visibility="{Binding PersonalBookings.Count, Converter={StaticResource NumToVis}, ConverterParameter='Inverted'}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
