<Window x:Class="QuanLySCL.GUI.Views.VietQRWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:QuanLySCL.GUI.ViewModels"
        mc:Ignorable="d"
        Title="Thanh toán VietQR" Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        d:DataContext="{d:DesignInstance Type=viewmodels:VietQRViewModel}">

    <Border CornerRadius="20" Background="{DynamicResource MaterialDesignPaper}" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <materialDesign:ColorZone Mode="PrimaryMid" CornerRadius="20,20,0,0" Padding="16">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Qrcode" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="THANH TOÁN VIETQR" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Style="{StaticResource MaterialDesignIconButton}" 
                            Command="{Binding CancelPaymentCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Foreground="White">
                        <materialDesign:PackIcon Kind="Close"/>
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Border Padding="24">
                    <StackPanel>
                        <!-- QR Code Container -->
                        <materialDesign:Card Padding="16" UniformCornerRadius="12" Background="White" Margin="0,0,0,16">
                            <StackPanel>
                                <Image Source="{Binding QrCodeUrl}" 
                                       Width="300" Height="300" 
                                       Stretch="Uniform" 
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <Separator Margin="0,16" Style="{StaticResource MaterialDesignLightSeparator}"/>

                                <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} đ}"
                                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding OrderDescription}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"
                                           Opacity="0.7"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Bank Info Card -->
                        <materialDesign:Card Padding="16" UniformCornerRadius="12" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Ngân hàng" Opacity="0.6"/>
                                    <TextBlock Text="{Binding BankName}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Số tài khoản" Opacity="0.6"/>
                                    <TextBlock Text="{Binding AccountNumber}" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Chủ tài khoản" Opacity="0.6"/>
                                    <TextBlock Text="{Binding AccountName}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Background="{DynamicResource PrimaryHueLightBrush}" Padding="12" UniformCornerRadius="8">
                            <TextBlock Text="Vui lòng kiểm tra kỹ số tài khoản và số tiền trước khi xác nhận." 
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"/>
                        </materialDesign:Card>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,0,24,24">
                <StackPanel>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding ConfirmPaymentCommand}"
                            Height="50"
                            materialDesign:ButtonAssist.CornerRadius="25"
                            Content="XÁC NHẬN ĐÃ NHẬN TIỀN"/>

                    <TextBlock Text="Nhấn xác nhận sau khi bạn đã kiểm tra tài khoản ngân hàng"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Opacity="0.5"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
