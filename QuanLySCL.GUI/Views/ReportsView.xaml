<Page x:Class="QuanLySCL.GUI.Views.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:vm="clr-namespace:QuanLySCL.GUI.ViewModels"
      Title="Báo cáo">

    <Page.DataContext>
        <vm:ReportsViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">
            <!-- Header -->
            <Grid Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="Báo cáo &amp; phân tích" FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Theo dõi hiệu quả hoạt động và chỉ số kinh doanh" FontSize="14" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox Width="140" Margin="0,0,12,0" 
                              ItemsSource="{Binding TimeRanges}"
                              SelectedItem="{Binding SelectedTimeRange}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="Custom">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <DatePicker SelectedDate="{Binding FromDate}" Width="130" Margin="0,0,8,0"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="130"/>
                    </StackPanel>

                    <Button Style="{StaticResource LimeButton}" Command="{Binding ExportCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Xuất báo cáo"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- KPI Cards -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Tổng doanh thu" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Summary.TotalRevenue, StringFormat='₫{0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <materialDesign:PackIcon Kind="TrendingUp" Width="14" Height="14" Foreground="#10B981" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding Summary.RevenueGrowth, StringFormat='{}{0}%'}" FontSize="13" Foreground="#10B981"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="Tổng số lượt đặt" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Summary.TotalBookings}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="Trung bình/ngày" FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Summary.AvgRevenuePerDay, StringFormat='₫{0:N0}'}" FontSize="24" FontWeight="Bold" Foreground="#0F172A" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Phân bổ doanh thu" FontSize="13" Foreground="#64748B"/>
                        <lvc:PieChart Series="{Binding CategorySeriesKPI}" Height="60" LegendLocation="None" Hoverable="False"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Revenue Chart -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Xu hướng doanh thu" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,20"/>
                        <Border Height="300" Background="#FFFF" CornerRadius="8">
                            <lvc:CartesianChart Series="{Binding RevenueSeries}" LegendLocation="Bottom">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Tháng" Labels="{Binding RevenueLabels}"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Doanh thu" LabelFormatter="{Binding Formatter}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Top Customers -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Khách hàng hàng đầu" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                            <Button Grid.Column="1" Content="Xem chi tiết" Padding="12,6" Style="{StaticResource OutlineButton}" Click="ViewTopCustomers_Click"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding TopCustomers}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MaxHeight="320"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#84CC16" BorderThickness="3,0,0,0" Padding="10,6" Margin="0,0,0,8">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" Background="#0F172A" CornerRadius="14" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding TotalBookings}" FontSize="12" FontWeight="Bold" Foreground="#84CC16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding TotalBookings, StringFormat={}{0} lượt đặt}" FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="{Binding TotalSpent, StringFormat='₫{0:N0}'}" FontSize="12" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Doanh thu theo sân" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding CourtRevenue}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  GridLinesVisibility="None" HeadersVisibility="Column" AlternatingRowBackground="#F8FAFC"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MaxHeight="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Sân" Binding="{Binding CourtName}" Width="*"/>
                                <DataGridTextColumn Header="Doanh thu" Binding="{Binding Revenue, StringFormat='₫{0:N0}'}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Doanh thu theo dịch vụ" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding ServiceRevenue}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  GridLinesVisibility="None" HeadersVisibility="Column" AlternatingRowBackground="#F8FAFC"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MaxHeight="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Dịch vụ" Binding="{Binding ServiceName}" Width="*"/>
                                <DataGridTextColumn Header="Doanh thu" Binding="{Binding Revenue, StringFormat='₫{0:N0}'}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Additional Insights -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Phân bổ doanh thu chi tiết" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,20"/>
                    <Border Height="300" Background="#FFFF" CornerRadius="8">
                        <lvc:PieChart Series="{Binding CategorySeries}" LegendLocation="Right" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
